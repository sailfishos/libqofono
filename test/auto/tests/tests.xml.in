<?xml version="1.0" encoding="UTF-8"?>
<testdefinition version="1.0">
  <suite name="libqofono-qt5-tests">
    <set name="libqofono-qt5-unit-tests">
      <description>Ofono test set with manual, automatic and semi-automatic case.</description>
      <pre_steps>
        <step>/usr/sbin/mcetool --set-never-blank=disabled --set-demo-mode=off --block=1 --set-never-blank=enabled --unblank-screen --block=1 --set-tklock-mode=unlocked</step>
      </pre_steps>
      <post_steps>
        <step>/usr/sbin/mcetool --set-never-blank=disabled --set-demo-mode=off</step>
      </post_steps>
      <case name="tst_qofonocallbarring">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonocallbarring</step>
      </case>
      <case name="tst_qofonocallforwarding">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonocallforwarding</step>
      </case>
      <case name="tst_qofonocallmeter">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonocallmeter</step>
      </case>
      <case name="tst_qofonocallsettings">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonocallsettings</step>
      </case>
      <case name="tst_qofonocallvolume">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonocallvolume</step>
      </case>
      <case manual="true" name="tst_qofonocellbroadcast">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonocellbroadcast</step>
      </case>
      <case manual="true" name="tst_qofonoconnmancontext">
        <!-- EXPECTFAIL: Not supported by Sailfish ofono -->
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonoconnmancontext</step>
      </case>
      <case name="tst_qofonoconnman">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonoconnman</step>
      </case>
      <case manual="true" name="tst_qofonomanager">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonomanager</step>
      </case>
      <case name="tst_qofonomessagemanager">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonomessagemanager</step>
      </case>
      <case name="tst_qofonomessagewaiting">
      <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonomessagewaiting</step>
      </case>
      <case manual="true" name="tst_qofonomodem">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonomodem</step>
      </case>
      <case manual="true" name="tst_qofonomultipartycall">
        <!-- EXPECTFAIL: Not aligned with the current API -->
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonomultipartycall</step>
      </case>
      <case name="tst_qofononetworkoperator">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofononetworkoperator</step>
      </case>
      <case name="tst_qofononetworkregistration">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofononetworkregistration</step>
      </case>
      <case name="tst_qofonophonebook">
      <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonophonebook</step>
      </case>
      <case insignificant="true" name="tst_qofonoradiosettings">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonoradiosettings</step>
      </case>
      <case name="tst_qofonosimmanager">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonosimmanager</step>
      </case>
      <case name="tst_qofonosupplementaryservices">
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonosupplementaryservices</step>
      </case>
      <case manual="true" name="tst_qofonovoicecall">
        <!-- EXPECTFAIL: Not aligned with the current API -->
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonovoicecall</step>
      </case>
      <case manual="true" name="tst_qofonovoicecallmanager">
        <!-- EXPECTFAIL: Not aligned with the current API -->
        <step>/usr/${CMAKE_INSTALL_LIBEXECDIR}/libqofono-qt${QT_MAJOR_VERSION}/tests/runtest.sh tst_qofonovoicecallmanager</step>
      </case>
    </set>
  </suite>
</testdefinition>
